{
  "compilerOptions": {
    "target": "esnext",
    "module": "es2020",
    "moduleResolution": "node",
    "types": ["node", "vitest/globals"],
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "jsx": "react",
    "baseUrl": "packages/",
    "skipLibCheck": true //TODO Fjern denne
  },
  "include": ["packages/**/*", "@types", "cypress.config.ts", "vite.config.ts", "vitest.config.ts"]
}
