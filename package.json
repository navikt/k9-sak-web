{
  "name": "k9-sak-web",
  "description": "Klient for K9",
  "main": "./dist/index.js",
  "type": "module",
  "author": "NAV",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navikt/k9-sak-web.git"
  },
  "scripts": {
    "test": "vitest",
    "test:all:testonly": "vitest --project test",
    "test:watch": "vitest --watch --silent=false",
    "test:watch:all": "vitest --watchAll",
    "test:coverage": "vitest --coverage --project test",
    "test-storybook": "test-storybook --url http://127.0.0.1:9001 --testTimeout=30_000",
    "ts-check": "tsc | loose-ts-check && tsc --pretty --project packages/v2/tsconfig.json",
    "ts-check:update-ignored": "tsc | loose-ts-check --auto-update && tsc --pretty --project packages/v2/tsconfig.json",
    "ts-check:v2": "tsc --pretty --project packages/v2/tsconfig.json",
    "lint": "eslint --cache packages",
    "lint:fix": "eslint --fix --cache packages",
    "css:lint": "stylelint \"packages/**/*.css\"",
    "css:modules:typegen": "vite-css-modules './packages/v2/gui/**/*.module.css' --config v2css.vite.config.ts",
    "ltb": "yarn ts-check && yarn lint && yarn css:lint && yarn build",
    "dev": "yarn cross-env APP_URL_K9FORMIDLING=http://localhost:8060/rest/dummy vite serve",
    "dev-lokal": "cross-env NODE_ENV=development APP_URL_SAK=http://k9-sak:8080 APP_URL_UNG_SAK=http://k9-sak:8085 APP_URL_K9OPPDRAG=http://k9-oppdrag:8070 APP_URL_K9FORMIDLING_DD=http://k9-formidling-dokumentdata:8294 APP_URL_K9FORMIDLING=http://localhost:8290 SPLITTET_SAMMENLINGNING_BEREGNING=true vite serve",
    "dev-med-formidling": "yarn cross-env APP_URL_K9FORMIDLING=http://k9-formidling:8290 SPLITTET_SAMMENLINGNING_BEREGNING=true vite serve",
    "build": "VITE_SENTRY_RELEASE=$(git rev-parse --short HEAD) vite build",
    "up": "docker-compose up -d --remove-orphans --build",
    "down": "docker-compose down",
    "preview": "vite preview",
    "storybook": "VITE_LOCAL_STORYBOOK=true storybook dev -p 9001",
    "build-storybook": "storybook build -o .static_storybook",
    "build-storybook-test": "VITE_LOCAL_STORYBOOK=true storybook build --test -o .static_storybook",
    "prepare": "lefthook install",
    "knip": "knip",
    "knip:check": "knip --include files,dependencies,exports --no-config-hints",
    "dev:ung": "vite -c ung.vite.config.js serve",
    "dev:aktivitetspenger": "vite -c aktivitetspenger.vite.config.js serve",
    "build:ung": "VITE_SENTRY_RELEASE=$(git rev-parse --short HEAD) vite -c ung.vite.config.js build"
  },
  "workspaces": [
    "packages/*",
    "packages/ung/*",
    "packages/v2/*"
  ],
  "dependencies": {
    "@hookform/error-message": "2.0.1",
    "@navikt/aksel-icons": "8.14.0",
    "@navikt/ds-css": "8.14.0",
    "@navikt/ds-react": "8.14.0",
    "@navikt/ds-tailwind": "8.14.0",
    "@navikt/endringslogg": "2.0.1",
    "@navikt/ft-plattform-komponenter": "12.0.11",
    "@navikt/ft-utils": "5.0.9",
    "@popperjs/core": "2.11.8",
    "@sentry/browser": "10.63.0",
    "axios": "1.18.1",
    "date-fns": "4.4.0",
    "dayjs": "1.11.21",
    "history": "5.3.0",
    "i18n-iso-countries": "7.14.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-intl": "10.1.14",
    "react-router": "7.17.0",
    "vite-plugin-svgr": "5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@sentry/vite-plugin": "5.3.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@storybook/test-runner": "0.24.4",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.2",
    "@types/object-hash": "3.0.6",
    "@types/prop-types": "15.7.15",
    "@types/react": "19.2.15",
    "@types/react-collapse": "5.0.4",
    "@types/redux-form": "8.3.11",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/eslint-plugin": "1.6.20",
    "axios-mock-adapter": "2.1.0",
    "cross-env": "10.1.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "knip": "6.24.0",
    "lefthook": "2.1.9",
    "loose-ts-check": "2.0.0",
    "msw": "2.14.6",
    "msw-storybook-addon": "2.0.7",
    "prettier": "3.9.4",
    "storybook": "10.4.6",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vite-css-modules": "1.16.0",
    "vite-plugin-html": "3.2.2",
    "vitest": "4.1.9",
    "vitest-axe": "0.1.0"
  },
  "resolutions": {
    "parse-url": "8.1.0",
    "@types/react": "19.0.3"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "packageManager": "yarn@4.14.1"
}
